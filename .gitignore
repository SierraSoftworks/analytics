# Generated by Cargo
# will have compiled files and executables
/target/
# The `ui` crate is excluded from the workspace, so it has its own target dir.
/ui/target/

# These are backup files generated by rustfmt
**/*.rs.bk

local.settings.json

/rex
/rex.exe
*.sqldb

# Frontend build output (regenerated by `trunk build`; a placeholder is created by agent/build.rs)
/ui/dist/

# Tracking beacon build output (regenerated by `npm run build` in tracker/; a
# placeholder is created by agent/build.rs) and its toolchain dependencies.
/tracker/dist/
/tracker/node_modules/

# Runtime data stores
*.redb
/parquet-store/
